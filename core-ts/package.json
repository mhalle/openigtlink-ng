{
  "name": "@openigtlink/core",
  "version": "0.1.0",
  "description": "Typed TypeScript wire codec for the OpenIGTLink protocol.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./messages": {
      "types": "./dist/messages/index.d.ts",
      "import": "./dist/messages/index.js"
    },
    "./messages/*": {
      "types": "./dist/messages/*.d.ts",
      "import": "./dist/messages/*.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./runtime/*": {
      "types": "./dist/runtime/*.d.ts",
      "import": "./dist/runtime/*.js"
    },
    "./net": {
      "types": "./dist/net/index.d.ts",
      "import": "./dist/net/index.js"
    },
    "./net/ws": {
      "types": "./dist/net/ws/index.d.ts",
      "import": "./dist/net/ws/index.js"
    },
    "./net/*": {
      "types": "./dist/net/*.d.ts",
      "import": "./dist/net/*.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:browser",
    "build:browser": "esbuild src/browser.ts --bundle --format=esm --platform=browser --target=es2022 --sourcemap --outfile=dist/browser.mjs",
    "test": "tsc -p tsconfig.json && node --test --test-reporter=spec \"build-tests/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "clean": "rm -rf dist build-tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "ws": "^8.20.0"
  }
}

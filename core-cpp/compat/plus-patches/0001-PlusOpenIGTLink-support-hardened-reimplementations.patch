-    msg->m_MetaDataMap = this->m_MetaDataMap;
-    msg->m_IsExtendedHeaderUnpacked = this->m_IsExtendedHeaderUnpacked;
-#endif
+    IGTL_PLUS_CLONE_RECEIVED_STATE(*msg, *this);
 
     return clone;
   }
diff --git a/src/PlusOpenIGTLink/igtlPlusMessageCompat.h b/src/PlusOpenIGTLink/igtlPlusMessageCompat.h
new file mode 100644
index 0000000..b6db67c
--- /dev/null
+++ b/src/PlusOpenIGTLink/igtlPlusMessageCompat.h
@@ -0,0 +1,124 @@
+/*=Plus=header=begin======================================================
+Program: Plus
+Copyright (c) Laboratory for Percutaneous Surgery. All rights reserved.
+See License.txt for details.
+=========================================================Plus=header=end*/
+
+// igtlPlusMessageCompat.h — implementation-detail bridge between
+// PLUS's custom igtl::* message classes and whichever build of
+// OpenIGTLink they're linked against.
+//
+// PLUS's custom messages (PlusClientInfoMessage, PlusUsMessage,
+// PlusTrackedFrameMessage) historically reach into protected
+// members of igtl::MessageBase to implement Clone() and to compute
+// raw-pointer offsets into the content region. That works against
+// the upstream OpenIGTLink C++ library, but a hardened
+// reimplementation may want to expose the same capability through
+// a sanctioned, bounds-aware tier-2 API rather than re-exposing
+// the raw protected internals.
+//
+// This header centralises that choice in one place. The macros
+// below expand inside a member function of a class that derives
+// from igtl::MessageBase (so the protected-member access is
+// legal). Detection is automatic via __has_include — no
+// build-system flags, no consumer-visible defines.
+//
+// **Safe path** (taken when <igtl/igtlSafeMessageHelpers.h> is
+// reachable on the include path — the openigtlink-ng compat shim
+// ships it):
+//
+//   - IGTL_PLUS_CLONE_RECEIVED_STATE(self, src) calls the
+//     sanctioned protected method
+//     `MessageBase::CopyReceivedFrom(src)`, which copies header
+//     fields, content, metadata, and v2/v3 extended-header state
+//     in one bounds-checked operation.
+//
+//   - IGTL_PLUS_CONTENT_BYTES(self) calls the sanctioned protected
+//     accessor `MessageBase::GetContentPointer()`, returning a
+//     pointer to the start of the content region.
+//
+// **Upstream path** (taken when the safe-helpers header is not
+// found on the include path — i.e. linking against the original
+// OpenIGTLink C++ library):
+//
+//   - IGTL_PLUS_CLONE_RECEIVED_STATE(self, src) replays the
+//     historical InitBuffer / CopyHeader / AllocateBuffer /
+//     CopyBody sequence, plus the v2+ metadata-copy block.
+//
+//   - IGTL_PLUS_CONTENT_BYTES(self) returns `self.m_Content`
+//     directly, matching the original PLUS code prior to
+//     introducing this helper.
+//
+// Both paths produce identical observable behavior; the safe
+// path adds bounds-checks beneath the hood.
+
+#ifndef __igtlPlusMessageCompat_h
+#define __igtlPlusMessageCompat_h
+
+#include "igtlMessageBase.h"
+#include "igtl_header.h"
+
+// Self-detect which OpenIGTLink build is on the include path.
+// __has_include is C++17 standard; the outer defined() guard
+// makes the test portable to compilers that pre-date C++17.
+#if defined(__has_include)
+#  if __has_include(<igtl/igtlSafeMessageHelpers.h>)
+#    include <igtl/igtlSafeMessageHelpers.h>
+#    define IGTL_PLUS_HAS_SAFE_API 1
+#  endif
+#endif
+
+// ---------------------------------------------------------------
+// Clone-received-state — replaces the historical 5-line sequence
+// with a single sanctioned call when the safe API is present.
+// ---------------------------------------------------------------
+#ifdef IGTL_PLUS_HAS_SAFE_API
+
+#  define IGTL_PLUS_CLONE_RECEIVED_STATE(self, src)               \
+     do { (self).CopyReceivedFrom(src); } while (0)
+
+#else
+
+#  define IGTL_PLUS_CLONE_RECEIVED_STATE(self, src)               \
+     do {                                                         \
+       int igtl_plus_compat_body_size_ =                          \
+         (src).m_MessageSize - IGTL_HEADER_SIZE;                  \
+       (self).InitBuffer();                                       \
+       (self).CopyHeader(&(src));                                 \
+       (self).AllocateBuffer(igtl_plus_compat_body_size_);        \
+       if (igtl_plus_compat_body_size_ > 0) {                     \
+         (self).CopyBody(&(src));                                 \
+       }                                                          \
+       IGTL_PLUS_COMPAT_COPY_V2_METADATA_(self, src);             \
+     } while (0)
+
+#  if OpenIGTLink_HEADER_VERSION >= 2
+#    define IGTL_PLUS_COMPAT_COPY_V2_METADATA_(self, src)         \
+       do {                                                       \
+         (self).m_MetaDataHeader           = (src).m_MetaDataHeader; \
+         (self).m_MetaDataMap              = (src).m_MetaDataMap;    \
+         (self).m_IsExtendedHeaderUnpacked = (src).m_IsExtendedHeaderUnpacked; \
+       } while (0)
+#  else
+#    define IGTL_PLUS_COMPAT_COPY_V2_METADATA_(self, src) ((void)0)
+#  endif
+
+#endif
+
+// ---------------------------------------------------------------
+// Content-bytes accessor — used by PlusTrackedFrameMessage's
+// pack/unpack paths to compute raw pointer offsets into the
+// content region.
+// ---------------------------------------------------------------
+#ifdef IGTL_PLUS_HAS_SAFE_API
+
+#  define IGTL_PLUS_CONTENT_BYTES(self)                           \
+     (reinterpret_cast<unsigned char*>((self).GetContentPointer()))
+
+#else
+
+#  define IGTL_PLUS_CONTENT_BYTES(self)  ((self).m_Content)
+
+#endif
+
+#endif /* __igtlPlusMessageCompat_h */
diff --git a/src/PlusOpenIGTLink/igtlPlusTrackedFrameMessage.cxx b/src/PlusOpenIGTLink/igtlPlusTrackedFrameMessage.cxx
index 0dd2536..9b57557 100644

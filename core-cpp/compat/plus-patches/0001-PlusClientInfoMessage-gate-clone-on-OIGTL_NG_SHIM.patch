+
+  //----------------------------------------------------------------------------
+  void PlusClientInfoMessage::CloneReceivedStateFrom(const PlusClientInfoMessage& src)
+  {
+#ifdef OIGTL_NG_SHIM
+    // Sanctioned tier-2 API on the hardened shim — handles header
+    // fields, content region, metadata map, and v2/v3 extended-
+    // header state in one bounds-aware call.
+    this->CopyReceivedFrom(src);
+#else
+    // Original upstream idiom — reaches into MessageBase's
+    // protected members directly.
+    int bodySize = src.m_MessageSize - IGTL_HEADER_SIZE;
+    this->InitBuffer();
+    this->CopyHeader(&src);
+    this->AllocateBuffer(bodySize);
     if (bodySize > 0)
     {
-      msg->CopyBody(this);
+      this->CopyBody(&src);
     }
 
-#if OpenIGTLink_HEADER_VERSION >= 2
-    msg->m_MetaDataHeader = this->m_MetaDataHeader;
-    msg->m_MetaDataMap = this->m_MetaDataMap;
-    msg->m_IsExtendedHeaderUnpacked = this->m_IsExtendedHeaderUnpacked;
+  #if OpenIGTLink_HEADER_VERSION >= 2
+    this->m_MetaDataHeader = src.m_MetaDataHeader;
+    this->m_MetaDataMap = src.m_MetaDataMap;
+    this->m_IsExtendedHeaderUnpacked = src.m_IsExtendedHeaderUnpacked;
+  #endif
 #endif
-
-    return clone;
   }
 
   //----------------------------------------------------------------------------

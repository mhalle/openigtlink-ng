 // IGTL includes
+#include <igtlMacro.h>       // OIGTL_NG_SHIM feature-test macro (shim only)
 #include <igtl_header.h>
 #include <igtl_util.h>
 
@@ -37,22 +38,37 @@ namespace igtl
 
     igtl::PlusClientInfoMessage::Pointer msg = dynamic_cast<igtl::PlusClientInfoMessage*>(clone.GetPointer());
 
-    int bodySize = this->m_MessageSize - IGTL_HEADER_SIZE;
-    msg->InitBuffer();
-    msg->CopyHeader(this);
